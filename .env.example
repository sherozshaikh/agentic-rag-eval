# ==================================================================
# agentic-rag-eval — environment variables
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# ==================================================================

# ----- LLM backend (reasoning agent) -----
# Options: "local" (Ollama) | "api" (OpenRouter/Google AI Studio)
LLM_BACKEND=local
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_TIMEOUT_SECONDS=300
LLM_MAX_RETRIES=0
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=8.0

# ----- Evaluation LLM (must differ from reasoning LLM to avoid self-eval bias) -----
EVAL_LLM_BACKEND=api
EVAL_LLM_MODEL=google/gemini-2.5-flash
EVAL_LLM_API_BASE=https://openrouter.ai/api/v1
EVAL_LLM_API_KEY=
EVAL_LLM_TIMEOUT_SECONDS=30

# ----- Qdrant -----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=hotpotqa_passages
QDRANT_USE_GRPC=false

# ----- Embeddings -----
DENSE_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL=Qdrant/bm25
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ----- Agent constraints -----
MAX_AGENT_STEPS=5
CONTEXT_BUDGET_TOKENS=16000
GENERATION_RESERVE_TOKENS=2000

# ----- Dataset -----
HOTPOTQA_SUBSET_SIZE=5000
HOTPOTQA_RANDOM_SEED=42

# ----- Tracing + storage -----
TRACE_DB_PATH=./traces/traces.duckdb
TRACE_RETENTION_DAYS=30

# ----- Memory (Mem0) -----
MEM0_STORAGE_PATH=./mem0_storage

# ----- API serving -----
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=
RATE_LIMIT=60/minute
CORS_ORIGINS=http://localhost:8000

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=json